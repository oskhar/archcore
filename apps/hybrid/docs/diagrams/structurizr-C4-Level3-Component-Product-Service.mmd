        style 11 fill:#ffffff,stroke:#1168bd,color:#1168bd
        12["<div style='font-weight: bold'>CommandBus</div><div style='font-size: 70%; margin-top: 0px'>[Component: @nestjs/cqrs CommandBus]</div><div style='font-size: 80%; margin-top:10px'>Mendispatch command ke<br />handler yang tepat:<br />CreateProductCommand,<br />UpdateProductCommand,<br />DeleteProductCommand.</div>"]
        style 12 fill:#ffffff,stroke:#1168bd,color:#1168bd
        13["<div style='font-weight: bold'>QueryBus</div><div style='font-size: 70%; margin-top: 0px'>[Component: @nestjs/cqrs QueryBus]</div><div style='font-size: 80%; margin-top:10px'>Mendispatch query ke handler<br />yang tepat: GetProductsQuery,<br />GetProductByIdQuery.</div>"]
        style 13 fill:#ffffff,stroke:#1168bd,color:#1168bd
        14["<div style='font-weight: bold'>CreateProductHandler</div><div style='font-size: 70%; margin-top: 0px'>[Component: @CommandHandler(CreateProductCommand)]</div><div style='font-size: 80%; margin-top:10px'>Membuat produk baru di DB<br />lalu memanggil<br />ProductProducer.emitProductCreated<br />(fire-and-forget).</div>"]
        style 14 fill:#ffffff,stroke:#1168bd,color:#1168bd
        15["<div style='font-weight: bold'>UpdateProductHandler</div><div style='font-size: 70%; margin-top: 0px'>[Component: @CommandHandler(UpdateProductCommand)]</div><div style='font-size: 80%; margin-top:10px'>Update produk di DB lalu emit<br />product.updated ke Kafka<br />untuk menjaga sales-service<br />cache tetap fresh.</div>"]
        style 15 fill:#ffffff,stroke:#1168bd,color:#1168bd
        16["<div style='font-weight: bold'>DeleteProductHandler</div><div style='font-size: 70%; margin-top: 0px'>[Component: @CommandHandler(DeleteProductCommand)]</div><div style='font-size: 80%; margin-top:10px'>Hapus produk dari DB lalu<br />emit product.deleted agar<br />sales-service dan<br />inventory-service<br />membersihkan cache/record<br />terkait.</div>"]
        style 16 fill:#ffffff,stroke:#1168bd,color:#1168bd
        17["<div style='font-weight: bold'>GetProductsHandler</div><div style='font-size: 70%; margin-top: 0px'>[Component: @QueryHandler(GetProductsQuery)]</div><div style='font-size: 80%; margin-top:10px'>Ambil semua produk dari DB<br />via TypeORM repository.</div>"]
        style 17 fill:#ffffff,stroke:#1168bd,color:#1168bd
        18["<div style='font-weight: bold'>GetProductByIdHandler</div><div style='font-size: 70%; margin-top: 0px'>[Component: @QueryHandler(GetProductByIdQuery)]</div><div style='font-size: 80%; margin-top:10px'>Ambil satu produk by UUID<br />dari DB. Throw<br />NotFoundException jika tidak<br />ada.</div>"]
        style 18 fill:#ffffff,stroke:#1168bd,color:#1168bd
        19["<div style='font-weight: bold'>Product Entity</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Entity('products') / TypeORM]</div><div style='font-size: 80%; margin-top:10px'>Fields: id (UUID PK), name,<br />price (decimal), description,<br />category. Extends BaseEntity<br />(createdAt, updatedAt,<br />version).</div>"]
        style 19 fill:#ffffff,stroke:#1168bd,color:#1168bd
        20["<div style='font-weight: bold'>TypeORM Repository<Product></div><div style='font-size: 70%; margin-top: 0px'>[Component: TypeORM Repository]</div><div style='font-size: 80%; margin-top:10px'>Diinjeksikan via<br />@InjectRepository(Product).<br />CRUD operations langsung ke<br />MySQL.</div>"]
        style 20 fill:#ffffff,stroke:#1168bd,color:#1168bd
        21["<div style='font-weight: bold'>ProductProducer</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Injectable() / OnModuleInit]</div><div style='font-size: 80%; margin-top:10px'>Kafka producer. Connects to<br />Kafka broker on init.<br />Methods: emitProductCreated,<br />emitProductUpdated,<br />emitProductDeleted. Semua<br />fire-and-forget.</div>"]
        style 21 fill:#ffffff,stroke:#1168bd,color:#1168bd
        22["<div style='font-weight: bold'>KafkaModule</div><div style='font-size: 70%; margin-top: 0px'>[Component: NestJS Module]</div><div style='font-size: 80%; margin-top:10px'>Registrasi ClientKafka dengan<br />KAFKA_SERVICE token. Consumer<br />group: product-consumer.<br />Brokers dari env<br />KAFKA_BROKERS.</div>"]
        style 22 fill:#ffffff,stroke:#1168bd,color:#1168bd
      end

