        style 38 fill:#ffffff,stroke:#1168bd,color:#1168bd
        39["<div style='font-weight: bold'>CommandBus</div><div style='font-size: 70%; margin-top: 0px'>[Component: @nestjs/cqrs CommandBus]</div><div style='font-size: 80%; margin-top:10px'>Mendispatch CreateSaleCommand<br />ke CreateSaleHandler.</div>"]
        style 39 fill:#ffffff,stroke:#1168bd,color:#1168bd
        40["<div style='font-weight: bold'>QueryBus</div><div style='font-size: 70%; margin-top: 0px'>[Component: @nestjs/cqrs QueryBus]</div><div style='font-size: 80%; margin-top:10px'>Mendispatch GetSaleQuery ke<br />GetSaleHandler.</div>"]
        style 40 fill:#ffffff,stroke:#1168bd,color:#1168bd
        41["<div style='font-weight: bold'>CreateSaleHandler</div><div style='font-size: 70%; margin-top: 0px'>[Component: @CommandHandler(CreateSaleCommand)]</div><div style='font-size: 80%; margin-top:10px'>Hot path: O(1) in-memory<br />lookup via<br />ProductCacheService.<br />Fallback: DB query jika cache<br />miss (eliminasi 91% failure<br />rate). Simpan transaksi via<br />SalesRepository.<br />Fire-and-forget emit<br />sales.transaction-completed<br />ke Kafka.</div>"]
        style 41 fill:#ffffff,stroke:#1168bd,color:#1168bd
        42["<div style='font-weight: bold'>GetSaleHandler</div><div style='font-size: 70%; margin-top: 0px'>[Component: @QueryHandler(GetSaleQuery)]</div><div style='font-size: 80%; margin-top:10px'>Ambil SalesTransaction by<br />UUID beserta relasi items<br />dari SalesRepository.</div>"]
        style 42 fill:#ffffff,stroke:#1168bd,color:#1168bd
        43["<div style='font-weight: bold'>ProductEventConsumer (Sales)</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Controller() / @MessagePattern]</div><div style='font-size: 80%; margin-top:10px'>Kafka consumer untuk<br />sinkronisasi cache produk.<br />Menangani: product.created<br />(persist ke DB + update<br />in-memory cache),<br />product.updated (update DB +<br />cache), product.deleted<br />(hapus dari DB + cache).</div>"]
        style 43 fill:#ffffff,stroke:#1168bd,color:#1168bd
        44["<div style='font-weight: bold'>ProductCacheService</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Injectable() In-Memory Cache]</div><div style='font-size: 80%; margin-top:10px'>In-memory Map<id, {id, name,<br />price}>. Warm-up dari<br />product_cache table saat<br />startup. O(1) get/set/delete.<br />Diperbarui via Kafka events.</div>"]
        style 44 fill:#ffffff,stroke:#1168bd,color:#1168bd
        45["<div style='font-weight: bold'>SalesRepository</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Injectable() Custom Repository]</div><div style='font-size: 80%; margin-top:10px'>Custom repository untuk<br />transaksi penjualan.<br />createTransaction(totalPrice,<br />items): atomik insert<br />SalesTransaction +<br />SalesItems. findById(id):<br />dengan eager loading items.</div>"]
        style 45 fill:#ffffff,stroke:#1168bd,color:#1168bd
        46["<div style='font-weight: bold'>SalesProducer</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Injectable() / OnModuleInit]</div><div style='font-size: 80%; margin-top:10px'>Kafka producer. Connect on<br />init.<br />emitSaleCompleted(payload):<br />fire-and-forget emit<br />sales.transaction-completed.<br />Payload berisi transactionId,<br />items[], timestamp.</div>"]
        style 46 fill:#ffffff,stroke:#1168bd,color:#1168bd
        47["<div style='font-weight: bold'>SalesTransaction Entity</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Entity('sales_transactions') / TypeORM]</div><div style='font-size: 80%; margin-top:10px'>Fields: id (UUID PK),<br />totalPrice (decimal), status<br />(ENUM: COMPLETED/FAILED).<br />Relasi: OneToMany ke<br />SalesItem.</div>"]
        style 47 fill:#ffffff,stroke:#1168bd,color:#1168bd
        48["<div style='font-weight: bold'>SalesItem Entity</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Entity('sales_items') / TypeORM]</div><div style='font-size: 80%; margin-top:10px'>Fields: id (UUID PK),<br />transactionId (FK),<br />productId, quantity (int),<br />unitPrice (decimal).</div>"]
        style 48 fill:#ffffff,stroke:#1168bd,color:#1168bd
        49["<div style='font-weight: bold'>ProductCache Entity</div><div style='font-size: 70%; margin-top: 0px'>[Component: @Entity('product_cache') / TypeORM]</div><div style='font-size: 80%; margin-top:10px'>Fields: id (UUID PK), name,<br />price (decimal). Persistent<br />cache untuk warm-up setelah<br />restart service. Diperbarui<br />via Kafka events.</div>"]
        style 49 fill:#ffffff,stroke:#1168bd,color:#1168bd
        50["<div style='font-weight: bold'>KafkaModule</div><div style='font-size: 70%; margin-top: 0px'>[Component: NestJS Module]</div><div style='font-size: 80%; margin-top:10px'>Registrasi ClientKafka dengan<br />KAFKA_SERVICE token. Consumer<br />group: sales-consumer.<br />Brokers dari env<br />KAFKA_BROKERS.</div>"]
        style 50 fill:#ffffff,stroke:#1168bd,color:#1168bd
      end

