    "test:equal:us3": "npx artillery run scenarios/equal-sales-transaction.yml",
    "test:scale:us1": "npx artillery run scenarios/scale-product-lifecycle.yml",
    "test:scale:us2": "npx artillery run scenarios/scale-inventory-sync.yml",
    "test:scale:us3": "npx artillery run scenarios/scale-sales-transaction.yml",
    "lab:report": "ts-node src/scripts/generate-report.ts",
    "lab:report:equal": "ts-node src/scripts/generate-report.ts --filter EQUAL",
    "lab:report:scale": "ts-node src/scripts/generate-report.ts --filter SCALE",
    "lab:tradeoff": "ts-node src/scripts/generate-tradeoff-report.ts",
