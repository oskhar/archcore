    "state-rehydration:report:equal": "node scripts/state-rehydration-report.js --filter EQUAL",
    "state-rehydration:report:scale": "node scripts/state-rehydration-report.js --filter SCALE",
    "bottleneck:report": "ts-node src/scripts/generate-bottleneck-report.ts",
    "bottleneck:report:equal": "ts-node src/scripts/generate-bottleneck-report.ts --filter EQUAL",
    "bottleneck:report:scale": "ts-node src/scripts/generate-bottleneck-report.ts --filter SCALE"
