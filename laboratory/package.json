  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed:monolith": "ts-node src/scripts/seed.ts --architecture MONOLITH",
    "seed:hybrid": "ts-node src/scripts/seed.ts --architecture HYBRID",
    "db:refresh": "ts-node src/scripts/refresh-db.ts",
    "test:us1": "npx artillery run scenarios/us1-product-lifecycle.yml",
